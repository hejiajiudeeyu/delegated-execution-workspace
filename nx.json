{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "repos",
    "libsDir": "repos"
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/pnpm-workspace.yaml",
      "{workspaceRoot}/.npmrc",
      "{workspaceRoot}/tools/project-boundaries.yaml",
      "{workspaceRoot}/docs/cross-repo-change-process.md",
      "{workspaceRoot}/docs/developer-workflow.md"
    ]
  },
  "targetDefaults": {
    "test": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    },
    "integration": {
      "cache": false,
      "inputs": [
        "default",
        "^default"
      ]
    }
  },
  "pluginsConfig": {
    "@nx/js": {
      "analyzeSourceFiles": false
    }
  }
}
