    "deployability:status": "node tools/deployability-status.mjs",
    "deployability:gates": "node tools/deployability-gates.mjs",
    "deployability:doctor": "node tools/deployability-doctor.mjs",
    "deployability:dashboard": "node tools/deployability-dashboard.mjs",
    "deployability:action-plan": "node tools/deployability-action-plan.mjs",
    "deployability:profiles": "node tools/deployability-profiles.mjs",
    "deployability:commands": "node tools/deployability-commands.mjs",
    "deployability:runbook": "node tools/deployability-runbook.mjs",
    "deployability:menu": "node tools/deployability-menu.mjs",
    "deployability:recipe": "node tools/deployability-recipe.mjs",
    "deployability:handoff": "node tools/deployability-handoff.mjs",
