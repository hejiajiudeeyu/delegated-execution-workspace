    "test:deployability-menu": "node tools/deployability-menu.test.mjs",
    "test:deployability-recipe": "node tools/deployability-recipe.test.mjs",
    "test:deployability-handoff": "node tools/deployability-handoff.test.mjs",
    "test:deployability": "node tools/deployability-overview.test.mjs && node tools/deployability-quickstart.test.mjs && node tools/deployability-safety.test.mjs && node tools/deployability-explain.test.mjs && node tools/deployability-production.test.mjs && node tools/deployability-exposure.test.mjs && node tools/deployability-release.test.mjs && node tools/deployability-operator-checklist.test.mjs && node tools/deployability-readiness.test.mjs && node tools/deployability-roadmap.test.mjs && node tools/deployability-status.test.mjs && node tools/deployability-gates.test.mjs && node tools/deployability-doctor.test.mjs && node tools/deployability-dashboard.test.mjs && node tools/deployability-action-plan.test.mjs && node tools/deployability-profiles.test.mjs && node tools/deployability-pipeline-summaries.test.mjs && node tools/deployability-commands.test.mjs && node tools/deployability-runbook.test.mjs && node tools/deployability-menu.test.mjs && node tools/deployability-recipe.test.mjs && node tools/deployability-handoff.test.mjs && node tools/compat-status.test.mjs",
    "test:deployability-operations": "node tools/dev-doctor.test.mjs && node tools/local-stack.test.mjs && node tools/selfhost-kit.test.mjs && node tools/published-image-smoke.test.mjs && node tools/operator-onboarding.test.mjs",
    "test:compat-status": "node tools/compat-status.test.mjs",
    "test:mcp-golden-four": "node tools/mcp-golden-four.test.mjs",
    "test:agent-e2e": "AUTO_APPROVE=true python3 tools/agent-e2e/agent-e2e-test.py",
    "ci": "node tools/validate-submodules.mjs && node tools/validate-change-bundle.mjs && node tools/check-boundaries.mjs && node tools/contracts-check.mjs && node tools/source-integration-check.mjs"
