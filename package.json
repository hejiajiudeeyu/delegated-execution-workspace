{
  "name": "delegated-execution-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Synthetic monorepo superproject for delegated execution cross-repo development orchestration",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "bootstrap": "corepack pnpm install",
    "sync:local-contracts": "node tools/sync-local-contracts.mjs",
    "submodules:init": "git submodule update --init --recursive",
    "submodules:sync": "git submodule sync --recursive && git submodule update --init --recursive",
    "submodules:status": "node tools/validate-submodules.mjs",
    "graph": "NX_DAEMON=false nx graph",
    "affected:graph": "NX_DAEMON=false nx graph --affected",
    "affected:test": "NX_DAEMON=false nx affected -t test",
    "affected:integration": "NX_DAEMON=false nx affected -t integration",
    "check:submodules": "node tools/validate-submodules.mjs",
    "check:boundaries": "node tools/check-boundaries.mjs",
    "check:bundles": "node tools/validate-change-bundle.mjs",
    "test:contracts": "node tools/contracts-check.mjs",
    "test:integration": "node tools/source-integration-check.mjs",
    "dev:platform": "docker compose -f repos/platform/deploy/platform/docker-compose.yml --env-file repos/platform/deploy/platform/.env up -d --build",
    "dev:platform:down": "docker compose -f repos/platform/deploy/platform/docker-compose.yml --env-file repos/platform/deploy/platform/.env down -v",
    "dev:platform:restart": "docker compose -f repos/platform/deploy/platform/docker-compose.yml --env-file repos/platform/deploy/platform/.env down && docker compose -f repos/platform/deploy/platform/docker-compose.yml --env-file repos/platform/deploy/platform/.env up -d --build",
    "dev:relay": "corepack pnpm --dir repos/platform --filter @delexec/transport-relay run start",
    "dev:client:bootstrap": "corepack pnpm --dir repos/client --filter @delexec/ops exec node src/cli.js bootstrap --platform http://127.0.0.1:8080",
    "dev:client:status": "corepack pnpm --dir repos/client --filter @delexec/ops exec node src/cli.js status",
    "dev:client:supervisor": "corepack pnpm --dir repos/client --filter @delexec/ops exec node src/cli.js start",
    "dev:console:gateway": "corepack pnpm --dir repos/platform --filter @delexec/platform-console-gateway run start",
    "dev:console:ui": "corepack pnpm --dir repos/client --filter @delexec/ops-console exec vite --host 127.0.0.1 --port 4174 --strictPort",
    "dev:platform-console:ui": "corepack pnpm --dir repos/platform --filter @delexec/platform-console exec vite --host 127.0.0.1 --port 4175 --strictPort",
    "dev:console": "corepack pnpm run dev:console:gateway & corepack pnpm run dev:console:ui",
    "dev:platform-console": "corepack pnpm run dev:console:gateway & corepack pnpm run dev:platform-console:ui",
    "dev:local:plan": "node tools/local-stack.mjs plan",
    "dev:local:up": "node tools/local-stack.mjs up",
    "dev:local:status": "node tools/local-stack.mjs status",
    "dev:local:down": "node tools/local-stack.mjs down",
    "dev:local:logs": "node tools/local-stack.mjs logs",
    "published-image:plan": "node tools/published-image-smoke.mjs plan",
    "published-image:smoke": "node tools/published-image-smoke.mjs smoke",
    "operator:onboarding:plan": "node tools/operator-onboarding.mjs plan",
    "operator:onboarding:check": "node tools/operator-onboarding.mjs check",
    "deployability:overview": "node tools/deployability-overview.mjs",
    "deployability:quickstart": "node tools/deployability-quickstart.mjs",
    "deployability:safety": "node tools/deployability-safety.mjs",
    "deployability:explain": "node tools/deployability-explain.mjs",
